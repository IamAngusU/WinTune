# PHP 8.2+ / MySQL 8+ configuration
DB_DSN="mysql:host=127.0.0.1;dbname=wintune;charset=utf8mb4"
DB_USER="wintune_api"
DB_PASSWORD="CHANGE_ME"
# Generate with: openssl rand -hex 32
APP_PEPPER="CHANGE_ME_TO_RANDOM_64_HEX_CHARACTERS"

# Browser Basic Auth for /admin. Create hash with:
# php -r "echo password_hash('change-this', PASSWORD_DEFAULT), PHP_EOL;"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD_HASH="CHANGE_ME"

# Must be outside public web root where possible.
RELEASE_ROOT="/var/www/wintune/storage/releases"

# Leave empty only when the API is mounted at the domain root.
API_BASE_PATH="/wintune/api"
